<Window x:Class="WindowCards.App.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowCards — atalhos"
        Width="500"
        Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="ToolWindow"
        Background="#FAFAFA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Border Background="#D32F2F" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="WC" Foreground="White" FontWeight="Bold" FontSize="14"/>
            </Border>
            <TextBlock Text="WindowCards"
                       FontSize="20"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="Cards visuais ancorados a qualquer janela do Windows."
                   Foreground="#555"
                   Margin="0,0,0,16"
                   TextWrapping="Wrap"/>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Atalhos globais" FontWeight="Bold" FontSize="13" Grid.ColumnSpan="3" Margin="0,0,0,8"/>

            <Border Grid.Row="1" Background="#EEE" CornerRadius="3" Padding="6,2" Margin="0,2,8,2" HorizontalAlignment="Left">
                <TextBlock x:Name="CreateOrEditLabel" FontFamily="Consolas" FontSize="12"/>
            </Border>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="Adicionar / editar card na janela em foco" VerticalAlignment="Center"/>
            <Button Grid.Row="1" Grid.Column="2"
                    Content="Alterar"
                    Width="80" Height="24"
                    Margin="8,2,0,2"
                    Click="OnChangeCreateOrEdit"/>

            <Border Grid.Row="2" Background="#EEE" CornerRadius="3" Padding="6,2" Margin="0,2,8,2" HorizontalAlignment="Left">
                <TextBlock x:Name="RemoveLabel" FontFamily="Consolas" FontSize="12"/>
            </Border>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="Remover card da janela em foco" VerticalAlignment="Center"/>
            <Button Grid.Row="2" Grid.Column="2"
                    Content="Alterar"
                    Width="80" Height="24"
                    Margin="8,2,0,2"
                    Click="OnChangeRemove"/>

            <TextBlock Grid.Row="3" Text="No card" FontWeight="Bold" FontSize="13" Grid.ColumnSpan="3" Margin="0,16,0,8"/>

            <TextBlock Grid.Row="4" Text="Arrastar com botão esquerdo" Margin="0,2"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Text="Reposicionar dentro da janela" Margin="0,2" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="5" Text="Botão direito" Margin="0,2"/>
            <TextBlock Grid.Row="5" Grid.Column="1" Text="Editar texto / Remover / Sair" Margin="0,2" VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Fechar"
                    Width="90"
                    Height="28"
                    IsCancel="True"
                    IsDefault="True"
                    Click="OnCloseClick"/>
        </StackPanel>
    </Grid>
</Window>
