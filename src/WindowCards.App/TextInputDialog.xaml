<Window x:Class="WindowCards.App.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Card"
        Width="380"
        Height="230"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="ToolWindow">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptLabel"
                   Text="Texto do card:"
                   Margin="0,0,0,6"
                   FontSize="13"/>

        <TextBox x:Name="InputBox"
                 Grid.Row="1"
                 FontSize="14"
                 Padding="6"
                 KeyDown="OnInputKeyDown"/>

        <TextBlock Grid.Row="2"
                   Text="Cor de fundo:"
                   Margin="0,12,0,6"
                   FontSize="13"/>

        <StackPanel x:Name="ColorSwatches"
                    Grid.Row="3"
                    Orientation="Horizontal"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar"
                    Width="90"
                    Height="28"
                    Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button Content="OK"
                    Width="90"
                    Height="28"
                    IsDefault="True"
                    Click="OnOkClick"/>
        </StackPanel>
    </Grid>
</Window>
