<Window x:Class="WindowCards.App.HotkeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Definir atalho"
        Width="420"
        Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="ToolWindow"
        Background="#FAFAFA"
        Focusable="True"
        PreviewKeyDown="OnPreviewKeyDown">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptLabel"
                   Text="Pressione a nova combinação de teclas:"
                   FontSize="13"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                BorderBrush="#888"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,16"
                Background="White">
            <TextBlock x:Name="ComboLabel"
                       Text="(aguardando…)"
                       FontFamily="Consolas"
                       FontSize="18"
                       HorizontalAlignment="Center"
                       Foreground="#444"/>
        </Border>

        <TextBlock Grid.Row="3"
                   x:Name="HintLabel"
                   Text="Use ao menos um modificador (Ctrl, Alt, Shift ou Win) + uma tecla."
                   Foreground="#777"
                   FontSize="11"
                   Margin="0,10,0,0"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar"
                    Width="90"
                    Height="28"
                    Margin="0,0,8,0"
                    IsCancel="True"/>
            <Button x:Name="OkButton"
                    Content="OK"
                    Width="90"
                    Height="28"
                    IsDefault="True"
                    IsEnabled="False"
                    Click="OnOkClick"/>
        </StackPanel>
    </Grid>
</Window>
